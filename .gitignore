# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
htmlcov/

# --- Virtual envs ---
.venv/
venv/
env/

# --- OS / editor ---
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*~

# --- App / agent session junk ---
.grok/
.superloopy/
agent-tools/
terminals/
tmp_qt_logs/
docs/codex-session-handoff.md

# --- Build outputs (never commit packaged apps) ---
build/
dist/
dist-*/
build-helper/**/*-build/
build-helper/UniversalMP4BrowserDownloader-build/
*.egg-info/
*.spec.bak

# --- Binaries / installers ---
*.exe
!build-helper/third_party/winsparkle/**/winsparkle-tool.exe
*.msi
*.dmg
*.pkg
*.app/
*.app.zip
*.dll
!build-helper/third_party/winsparkle/**/*.dll
*.so
*.dylib
*.bin
*.pdb
*.lib
!build-helper/third_party/winsparkle/**/*.lib

# --- Archives (easy to accidentally add huge zips) ---
*.zip
!build-helper/third_party/winsparkle/**/*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz
*.bz2
*.xz
*.iso

