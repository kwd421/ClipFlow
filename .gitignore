clipflow_*.png
clipflow-*.png
clipflow_*.jpg
clipflow-*.jpg
*_verify.png
*_preview.png

# --- Logs / temp / local dumps ---
*.tmp
*.temp
*.log
*.out
*.err
*.dmp
*.stackdump
verification-summary.json
*_diff*.txt
_verify_*.py
_git_*.py
_peek_*.py
